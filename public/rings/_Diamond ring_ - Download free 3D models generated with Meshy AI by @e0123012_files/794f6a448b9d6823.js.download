uniform float u_fresnelPower;
uniform float u_fresnelWhite;
uniform float u_fresnelAlpha;
uniform float u_time;

float computeFresnelTerm(vec3 normal, vec3 viewDir, float time) {
  // When time > 0 (cinematic mode), rotate viewDir around Y axis
  // to create a flowing light sweep across the surface.
  vec3 vd = viewDir;
  if (time > 0.0) {
    float c = cos(time);
    float s = sin(time);
    vd = vec3(c * viewDir.x - s * viewDir.z, viewDir.y, s * viewDir.x + c * viewDir.z);
  }
  return pow(1.0 - abs(dot(normal, vd)), u_fresnelPower);
}
