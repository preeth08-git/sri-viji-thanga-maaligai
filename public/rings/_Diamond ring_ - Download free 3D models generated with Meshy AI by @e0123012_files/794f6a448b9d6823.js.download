varying vec3 v_worldPos;
uniform mat4 u_cutterInvMatrix;
uniform int u_cutterType;
uniform int u_clipInvert;

float sdfBox(vec3 p, vec3 b) {
  vec3 q = abs(p) - b;
  return length(max(q, 0.0)) + min(max(q.x, max(q.y, q.z)), 0.0);
}

float sdfSphere(vec3 p, float r) {
  return length(p) - r;
}

float sdfCylinder(vec3 p, float r, float h) {
  vec2 d = abs(vec2(length(p.xz), p.y)) - vec2(r, h);
  return min(max(d.x, d.y), 0.0) + length(max(d, 0.0));
}

float sdfMortiseTenon(vec3 p) {
  // Base plate: 1.0 x 0.15 x 1.0 (half extents: 0.5, 0.075, 0.5)
  float base = sdfBox(p, vec3(0.5, 0.075, 0.5));
  // Tenon: 0.3 x 0.15 x 0.3, centered at y=0.15 (half extents: 0.15, 0.075, 0.15)
  float tenon = sdfBox(p - vec3(0.0, 0.15, 0.0), vec3(0.15, 0.075, 0.15));
  return min(base, tenon);
}

float evaluateSDF(vec3 localPos) {
  if (u_cutterType == 0) return sdfBox(localPos, vec3(0.5));
  if (u_cutterType == 1) return sdfSphere(localPos, 0.5);
  if (u_cutterType == 2) return sdfCylinder(localPos, 0.5, 0.5);
  if (u_cutterType == 3) return sdfMortiseTenon(localPos);
  return 1.0; // default: no clip
}
