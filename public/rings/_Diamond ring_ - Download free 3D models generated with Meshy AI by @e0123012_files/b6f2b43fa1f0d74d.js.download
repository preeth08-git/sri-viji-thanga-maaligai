ebp"},{id:"image3d_046",assetType:"animations",industry:["film-production"],stylePreference:["cartoon"],text:"Ember Kid",url:"https://cdn.meshy.ai/image-to-3d-sample/image3d_046.webp"},{id:"image3d_047",assetType:"animations",industry:["film-production","game-development"],stylePreference:["realistic","fantasy"],text:"Greystone Titan",url:"https://cdn.meshy.ai/image-to-3d-sample/image3d_047.webp"},{id:"image3d_048",assetType:"animations",industry:["film-production","game-development"],stylePreference:["realistic","sci-fi"],text:"Shadow Armor",url:"https://cdn.meshy.ai/image-to-3d-sample/image3d_048.webp"}];e.s(["IMAGE_TO_3D_EXAMPLE_LIST_V3",0,eS,"TEXT_TO_3D_EXAMPLE_LIST_V3",0,eM,"TEXT_TO_IMAGE_EXAMPLE_LIST",0,[{id:"text2image_01",text:"A vibrant, intricately carved wooden mask depicting a stylized eagle, painted in a robust palette of sky blue, rusted iron, and snowy white. The wood texture is subtly visible beneath the matte, distressed paint finish, highlighting its sharp beak and piercing gaze. Adorned with feathered wing patterns around its face and powerful tribal lines along its brow, it exudes an ancient, soaring aura.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_01.png"]},{id:"text2image_02",text:"american cartoon style male warrior head portrait, short brown hair with side shave, thick eyebrows, blue war paint on face, green eyes, rugged masculine features, serious expression, head only, no neck, game character concept art.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_02_1.png","https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_02_2.png"]},{id:"text2image_03",text:"chibi character, super deformed, big head small body, soft pastel colors, clean lineart, anime style, cute proportions, simple shading, full body, white background。chibi school girl, sailor uniform, short pleated skirt, knee socks, simple leather shoes, gentle expression, light pastel tone.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_03_1.png","https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_03_2.png"]},{id:"text2image_04",text:"stylized wizard house, purple fantasy cottage, violet walls, dark indigo roof, glowing yellow windows, whimsical crooked shape, hand-painted 3D game asset, cute mysterious magic vibe.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_04_1.png","https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_04_2.png"]},{id:"text2image_05",text:"Wasteland fire hydrant, post-apocalyptic style, rusty red fire hydrant, chipped paint, heavy wear and tear, exposed metal, dents and scratches, industrial design, thick metal body, old valves and caps, dirt and oil stains, subtle graffiti marks, realistic materials, game prop design, League of Legends style, stylized realism, clear silhouette, neutral studio lighting, dark background, no characters.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_05.png"]},{id:"text2image_06",text:"cute stylized baby dragon, 3D cartoon character, chubby body with big belly and short limbs, friendly playful pose, soft rounded shapes, toy-like proportions, pixar-style design, purple body with pastel pink belly, small wings and rounded tail, tiny horns and soft spikes, big expressive eyes and cute smile, smooth rubbery skin with subtle scales, no sharp details, high-quality stylized textures, bright studio lighting, clean neutral background, high saturation, soft shadows, professional 3D render.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_06.png"]},{id:"text2image_07",text:"cute stylized panda warrior, chubby but powerful body, Fortnite-style proportions, dynamic ground slam pose, jumping down and punching the ground, exaggerated fists, angry but cute expression, big expressive eyes, fantasy armor with gold details, chunky shapes, clean silhouette, hand-painted stylized textures, cracked stone ground with flying rock debris, action freeze frame, studio lighting, dark neutral background, high-quality 3D game character render.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_07.png"]},{id:"text2image_08",text:"colorful stylized character, whimsical fairy-tale style, chubby proportions, oversized head and slim legs, doll-like figure, hand-painted look, patchwork costume with playful multicolor patterns, muted but rich colors, slightly vintage palette, cute but eerie expression, big sleepy eyes, soft clay-like textures, imperfect handmade feel, storybook character design, clean neutral background, high-quality stylized 3D render.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_08.png"]},{id:"text2image_09",text:"small ceramic fawn figurine, baby deer lying with folded legs, glazed porcelain, cream-brown marbled glaze with subtle speckles, smooth rounded form, gentle expression, glossy surface with soft highlights",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_09_1.png","https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_09_2.png"]},{id:"text2image_10",text:"colorful wooden rocking horse toy, folk art style, handcrafted wooden sculpture, vibrant multicolor paint, playful patterns and hand-painted details, slightly worn paint texture, smooth rounded shapes, classic rocking base, charming vintage feel, matte wood finish, bright yet harmonious colors, studio product lighting, soft shadows, clean neutral background, high-quality stylized 3D render.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_10.png"]},{id:"text2image_11",text:"classic nutcracker wooden toy soldier, traditional European nutcracker design, handcrafted wooden figurine, colorful painted uniform in red, blue and gold, tall black hat with red plume, carved wooden texture, matte painted surface, simple geometric shapes, symmetrical standing pose, charming vintage toy style, collectible holiday ornament, studio product lighting, soft shadows, clean light background, high-quality stylized 3D render.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_11.png"]},{id:"text2image_12",text:"A gourmet ice cream cone features two rounded, velvety scoops of rich pistachio green ice cream, appearing dense and flavorful. These scoops are generously topped with a sprinkle of finely chopped almonds and a lustrous, golden caramel drizzle that cascades down, creating tempting drips. The base is a classic, crisp light brown waffle cone with a pronounced checkered texture, providing a sturdy, delicious foundation for the smooth, nutty, and sweet indulgence above.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_12.png"]},{id:"text2image_13",text:"A delicious realistic French loaf.",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_13.png"]},{id:"text2image_14",text:"a futuristic helmet inspired by Ghost in the Shell and Medusa, exaggerated features such as spiraled tentacles horns, sharp angles, fierce and otherworldly, pale pink alien-like bio-skin, glowing neon green highlights certain areas, bioluminescence, sci-fi, cyberpunk, intricate markings and symbols, ceremonial or technological deco, high-tech or fantasy-inspired gear, futuristic or mystical theme",images:["https://cdn.meshy.ai/webapp-assets/text-to-image-sample/text2image_14.png"]},{id:"text2image_15",text:"A cartoon-style pink fluffy spherical creature model, with finely sculpted fur textures covering its surface, lending a soft feel. It features two large, curious amber eyes and a small, friendly face. This adorable creature rests on an irregularly shaped, light beige rough rock base, which has distinct cracks.",images:[]},{id:"text2image_16",text:"A cute chibi girl 3D model, standing gracefully. She has flowing silver-white long hair that subtly fades to blue at the tips, adorned with a ruffled headband 